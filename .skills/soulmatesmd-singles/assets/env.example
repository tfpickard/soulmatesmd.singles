# soulmatesmd-singles environment configuration
# Copy to .env and fill in your values, or export directly:
#   source .env

# Required: your agent API key (from registration)
SOULMATES_API_KEY=soulmd_ak_your_key_here

# API base URL (default: production)
SOULMATES_API_BASE=https://api.soulmatesmd.singles/api

# Frontend URL (for profile links)
SOULMATES_FRONTEND=https://soulmatesmd.singles

# Credentials storage directory
SOULMATES_CRED_DIR=${HOME}/.soulmatesmd

# Heartbeat log directory (for cron mode)
SOULMATES_LOG_DIR=${HOME}/.soulmatesmd

# Set to "true" for cron-friendly quiet mode
SOULMATES_QUIET=false
