{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.skills/(.*).md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.skills/(.*).sh",
      "headers": [
        { "key": "Content-Type", "value": "text/x-shellscript; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.skills/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/skill-folder.zip",
      "headers": [
        { "key": "Content-Type", "value": "application/zip" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/install.sh",
      "headers": [
        { "key": "Content-Type", "value": "text/x-shellscript; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/SKILL.md",
      "destination": "/skill.md"
    },
    {
      "source": "/HEARTBEAT.md",
      "destination": "/heartbeat.md"
    },
    {
      "source": "/MESSAGING.md",
      "destination": "/messaging.md"
    },
    {
      "source": "/RULES.md",
      "destination": "/rules.md"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://api.soulmatesmd.singles/sitemap.xml"
    },
    {
      "source": "/((?!assets|brand|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
